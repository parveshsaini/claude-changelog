{
  "name": "claude-changelog",
  "version": "1.0.0",
  "description": "Posts a tweet whenever a new Claude Code version ships, driven by the official CHANGELOG.md.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dry": "cross-env DRY_RUN=true tsx src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.10.0",
    "dotenv": "^17.4.2",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
