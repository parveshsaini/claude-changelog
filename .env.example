# Google Gemini — generates the tweet text
GEMINI_API_KEY=

# X (Twitter) OAuth 1.0a user-context credentials.
# Create an app at https://developer.x.com with Read+Write permission,
# then generate an API key/secret and an access token/secret.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional: set to "true" to print tweets instead of posting them.
DRY_RUN=false
